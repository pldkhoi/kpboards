# ==============================================
# Required
# ==============================================
# LocalStorage key for auth tokens (required for JWT auth)
VITE_LOCAL_TOKEN=app_token
# Enable frontend mock auth mode in development only (true/false)
VITE_AUTH_MOCK_MODE=true

# ==============================================
# Required for API integration
# ==============================================
# API base URL (defaults to empty string if unset)
VITE_API_ENDPOINT=https://api.example.com
# Auth API base URL (defaults to empty string if unset)
VITE_AUTH_API_ENDPOINT=https://auth.example.com

# ==============================================
# Recommended
# ==============================================
# App identifier for API requests
VITE_X_APP_ID=your-app-id
# Release version for deployment
VITE_RELEASE_VERSION=1.0.0

# ==============================================
# Optional
# ==============================================
# Timezone header for API requests
# VITE_X_LOCAL_TIMEZONE_ID=X-LOCAL-TIMEZONE-ID
